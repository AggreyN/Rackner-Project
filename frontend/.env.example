# Copy this file to `.env` (in the frontend/ folder) and paste your real keys.
# The real `.env` is gitignored — it will NEVER be committed. Keep it that way.

# Backend API base URL. Leave UNSET to run the frontend against the built-in
# mock (no backend needed) — same idea as the extractor's mock fallback.
# Point it at Aggrey's local FastAPI or the deployed backend when available:
# NEXT_PUBLIC_API_URL=http://localhost:8000

# Auth feature flag — must match the backend's AUTH_ENABLED. Off by default
# so the demo stays frictionless.
# NEXT_PUBLIC_AUTH_ENABLED=1

# SAM.gov API key (shared team key, ~10 requests/day). Server-side only.
# Get one at https://sam.gov -> Account Details -> API Key
SAM_API_KEY=your-key-here
